generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  invites      Invite[]
}

model Invite {
  id        String         @id @default(cuid())
  userId    String
  slug      String         @unique
  brideName   String?
  groomName   String?
  weddingDate DateTime?
  views       Int            @default(0)
  data        Json
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([updatedAt])
  @@index([weddingDate])
}

enum InviteTemplate {
  MINIMAL
  ROYAL
  HINDU
  MUSLIM
  CHRISTIAN
  SIKH
  CIVIL
  LUXURY
  SOUTH_INDIAN
}
